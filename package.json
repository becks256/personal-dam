{
  "name": "dam",
  "version": "0.1.0",
  "description": "Local digital asset manager for images and video.",
  "main": "main.mjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --config vite.config.ts",
    "dev:electron": "cross-env NODE_ENV=development ELECTRON_DISABLE_SANDBOX=1 electron .",
    "build": "vite build --config vite.config.ts",
    "start": "cross-env NODE_ENV=production electron .",
    "test": "vitest --run",
    "rebuild": "electron-rebuild"
  },
  "postinstall": "electron-rebuild",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^29.4.6",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@types/react-window": "^1.8.8",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-window": "^2.2.7",
    "sharp": "^0.34.5",
    "zustand": "^5.0.12"
  }
}
